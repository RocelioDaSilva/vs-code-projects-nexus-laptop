63],"#Brandon Sanderson: Hard Magic Systems#The Three Laws of Magic#Law Three: Expand what you already have before adding something new.":[64,77],"#Brandon Sanderson: Hard Magic Systems#The Three Laws of Magic#Law Three: Expand what you already have before adding something new.#{1}":[66,77],"#Brandon Sanderson: Hard Magic Systems#Applying to Your Story":[78,126],"#Brandon Sanderson: Hard Magic Systems#Applying to Your Story#Action 1: Audit Your Magic Costs":[80,96],"#Brandon Sanderson: Hard Magic Systems#Applying to Your Story#Action 1: Audit Your Magic Costs#{1}":[82,96],"#Brandon Sanderson: Hard Magic Systems#Applying to Your Story#Action 2: Create a Magic Limitation that Creates Plot":[97,112],"#Brandon Sanderson: Hard Magic Systems#Applying to Your Story#Action 2: Create a Magic Limitation that Creates Plot#{1}":[99,112],"#Brandon Sanderson: Hard Magic Systems#Applying to Your Story#Action 3: Expand Flux-Weave, Don't Add Systems":[113,126],"#Brandon Sanderson: Hard Magic Systems#Applying to Your Story#Action 3: Expand Flux-Weave, Don't Add Systems#{1}":[115,126],"#Brandon Sanderson: Hard Magic Systems#Checklist: Hard Magic in Your Story":[127,138],"#Brandon Sanderson: Hard Magic Systems#Checklist: Hard Magic in Your Story#{1}":[129,138],"#Brandon Sanderson: Hard Magic Systems#Key Insight":[139,146],"#Brandon Sanderson: Hard Magic Systems#Key Insight#{1}":[141,146]},"outlinks":[],"task_lines":[129,130,131,132,133,134,135],"tasks":{"incomplete":{"all":[129,130,131,132,133,134,135],"top":[129,130,131,132,133,134,135]}},"codeblock_ranges":[]},"smart_blocks:writingtutorials/01-Brandon-Sanderson-Hard-Magic/VIDEO-TRANSCRIPTION.md#Brandon Sanderson: Hard Magic Systems": {"path":null,"last_embed":{"hash":"e4aap4","at":1775331715278},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.07953439,-0.07860383,0.00745942,0.01425325,-0.03060213,0.05493315,0.04156939,0.00022629,-0.01575273,-0.07439216,-0.03092556,-0.01186951,0.03001434,-0.00844107,-0.00356889,-0.05379043,0.00984826