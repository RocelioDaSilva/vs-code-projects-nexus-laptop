    def criar_grafico_principal(self, fig):
        """Cria gráfico principal para exportação"""
        ax = fig.add_subplot(111)
        
        # Dados
        labels = ['FBH', 'Wellhead', 'FPSO']
        temps = [self.resultados['system']['T_fbh'], 
                self.resultados['system']['T_wh'], 
                self.resultados['system']['T_fpso']]
        
        bars = ax.bar(labels, temps, color=['red', 'orange', 'green'])
        ax.set_ylabel('Temperatura (°C)', fontweight='bold')
        ax.set_title('Perfil de Temperatura - Sistema Completo', fontweight='bold')
        ax.axhline(y=45, color='orange', linestyle='--', label='WAT (45°C)')
        ax.axhline(y=20, color='red', linestyle='--', label='Hidratos (20°C)')
        ax.legend()
        ax.grid(True, alpha=0.3)
        
        # Valores nas barras
        for bar, temp in zip(bars, temps):
            height = bar.get_height()
            ax.text(bar.get_x() + bar.get_width()/2., height + 1,
                   f'{temp}°C', ha='center', va='bottom', fontweight='bold')
    
