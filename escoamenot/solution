    def exportar_resultados(self):
        """Exporta todos os resultados"""
        if not self.resultados:
            messagebox.showwarning("Aviso", "Execute um cálculo primeiro!")
            return
        
        # Criar diretório para exportação
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        diretorio = f"exportacao_termica_{timestamp}"
        
        try:
            os.makedirs(diretorio, exist_ok=True)
            
            # 1. Salvar dados em JSON
            dados = self.coletar_dados()
            with open(f"{diretorio}/dados_entrada.json", 'w') as f:
                json.dump(dados, f, indent=4)
            
            # 2. Salvar resultados em JSON
            with open(f"{diretorio}/resultados.json", 'w') as f:
                json.dump(self.resultados, f, indent=4, default=str)
            
            # 3. Salvar relatório em TXT
            relatorio = self.gerar_relatorio_completo()
            with open(f"{diretorio}/relatorio.txt", 'w', encoding='utf-8') as f:
                f.write(relatorio)
            
            # 4. Salvar gráfico
            fig, _ = plt.subplots(figsize=(10, 6))
            self.criar_grafico_principal(fig)
            fig.savefig(f"{diretorio}/grafico_principal.png", dpi=300, bbox_inches='tight')
            plt.close(fig)
            
            messagebox.showinfo("Sucesso", f"Exportação completa!\nArquivos salvos em: {diretorio}")
            
        except Exception as e:
            messagebox.showerror("Erro", f"Erro na exportação:\n{str(e)}")
    
    def gerar_relatorio_completo(self):
        """Gera um relatório completo em texto"""
        relatorio = f"""
        RELATÓRIO COMPLETO - CÁLCULO TÉRMICO
        ====================================
        
        Data: {datetime.now().strftime('%d/%m/%Y %H:%M:%S')}
        
        {self.gerar_secao_condicoes()}
        
        {self.gerar_secao_resultados()}
        
        {self.gerar_secao_analise()}
        
        {self.gerar_secao_conclusoes()}
        """
        return relatorio
    
    def gerar_secao_condicoes(self):
        """Gera seção de condições do relatório"""
        return """
        1. CONDIÇÕES OPERACIONAIS
        -------------------------
        Tipo de Poço: {}
        Região: {}
        Tipo de Fluido: {}
        Profundidade da Água: {} m
        """.format(
            self.resultados['condições']['tipo_poço'].upper(),
            self.resultados['condições']['região'].upper(),
            self.resultados['condições']['tipo_fluido'].upper(),
            self.resultados['condições']['profundidade_água']
        )
    
    def gerar_secao_resultados(self):
        """Gera seção de resultados do relatório"""
        return """
        2. RESULTADOS
        -------------
        Temperatura FBH: {} °C
        Temperatura Wellhead: {} °C
        Temperatura FPSO: {} °C
        Queda Total: {} °C
          - Queda no Poço: {} °C
          - Queda na Flowline: {} °C
        
        Perda Térmica Específica: {} W/m
        Potência Total Perdida: {} kW
        """.format(
            self.resultados['system']['T_fbh'],
            self.resultados['system']['T_wh'],
            self.resultados['system']['T_fpso'],
            self.resultados['system']['delta_T_total'],
            self.resultados['system']['delta_T_well'],
            self.resultados['system']['delta_T_flowline'],
            self.resultados['flowline']['q_prime'],
            self.resultados['flowline']['Q_total']
        )
    
    def gerar_secao_analise(self):
        """Gera seção de análise do relatório"""
        margem = self.resultados['system']['T_fpso'] - 45
        
        if margem > 15:
            status = "ADEQUADO"
            risco = "BAIXO"
        elif margem > 5:
            status = "MARGINAL"
            risco = "MODERADO"
        else:
            status = "INADEQUADO"
            risco = "ALTO"
        
        return """
        3. ANÁLISE DE RISCOS
        -------------------
        Temperatura de Referência:
        • Hidratos: 20 °C
        • Parafina (WAT): 45 °C
        
        Margens de Segurança:
        • Sobre WAT: {:.1f} °C
        • Sobre Hidratos: {:.1f} °C
        
        Status do Sistema: {}
        Nível de Risco: {}
        """.format(
            margem,
            self.resultados['system']['T_fpso'] - 20,
            status,
            risco
        )
    
    def gerar_secao_conclusoes(self):
        """Gera seção de conclusões do relatório"""
