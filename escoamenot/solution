            self.var_regiao.set("tropical")
            self.var_tipo_fluido.set("multifásico")
            self.var_profundidade_agua.set("1500")
            
            # Limpar resultados
            for widget in self.scroll_resultados.winfo_children():
                widget.destroy()
            
            for widget in self.frame_graficos.winfo_children():
