class CalculoTermicoPetroleo:
    """Classe para cálculos térmicos em linhas de produção de petróleo"""
    
    def __init__(self):
        """Inicializa a classe com constantes físicas"""
        # Constantes físicas
        self.g = 9.81  # m/s²
        self.pi = np.pi
    
    # ========================================================================
    # MÉTODOS DE CÁLCULO
    # ========================================================================
    
    def calcular_poço(self, params):
        """Calcula a temperatura no wellhead"""
        
        # Extrair parâmetros
        T_fbh = float(params['T_fbh'])
        TVD = float(params['TVD'])
        grad_geo = float(params['grad_geo'])
        T_sea_bottom = float(params['T_sea_bottom'])
        m_dot = float(params['m_dot'])
        Cp = float(params['Cp'])
        
        # Geometria do poço
        r_ti = float(params['r_ti'])
        r_to = float(params['r_to'])
        r_ci = float(params['r_ci'])
        r_co = float(params['r_co'])
        r_bh = float(params['r_bh'])
        
        # Condutividades térmicas
        k_steel = float(params['k_steel'])
        k_water = float(params['k_water'])
        k_cement = float(params['k_cement'])
        k_formation = float(params['k_formation'])
        
        # Coeficientes de convecção
        h_i = float(params['h_i'])
        
        # 1. Temperatura média da formação
        T_formation_avg = T_sea_bottom + grad_geo * (TVD / 2)
        
        # 2. Cálculo das resistências térmicas
        R_conv_i = 1 / (h_i * 2 * self.pi * r_ti)
        R_cond_tubing = np.log(r_to / r_ti) / (2 * self.pi * k_steel)
        R_cond_annulus = np.log(r_ci / r_to) / (2 * self.pi * k_water)
        R_cond_casing = np.log(r_co / r_ci) / (2 * self.pi * k_steel)
        R_cond_cement = np.log(r_bh / r_co) / (2 * self.pi * k_cement)
        R_formation = 1 / (2 * self.pi * k_formation) * np.log(2 * np.sqrt(0.0001 * 30 * 86400) / r_bh)
        
        # 3. Resistência total
        R_total = (R_conv_i + R_cond_tubing + R_cond_annulus + 
                  R_cond_casing + R_cond_cement + R_formation)
        
        # 4. Coeficiente global U
        A_o = 2 * self.pi * r_to
        U = 1 / (R_total * A_o)
        
        # 5. Parâmetro A
        A_param = (m_dot * Cp) / (2 * self.pi * r_to * U)
        
        # 6. Temperatura no wellhead
        T_wh = T_formation_avg + (T_fbh - T_formation_avg) * np.exp(-TVD / A_param)
        delta_T_well = T_fbh - T_wh
        
        # Resultados
        results = {
            'T_wh': round(T_wh, 2),
            'T_formation_avg': round(T_formation_avg, 2),
            'R_total': round(R_total, 4),
            'U': round(U, 2),
            'A_param': round(A_param, 0),
            'delta_T_well': round(delta_T_well, 2),
            'resistências': {
                'R_conv_i': round(R_conv_i, 6),
                'R_cond_tubing': round(R_cond_tubing, 6),
                'R_cond_annulus': round(R_cond_annulus, 4),
                'R_cond_casing': round(R_cond_casing, 6),
                'R_cond_cement': round(R_cond_cement, 4),
                'R_formation': round(R_formation, 4)
            }
        }
        
        return results
    
    def calcular_flowline(self, params, T_inlet):
        """Calcula a perda térmica na flowline"""
        
        # Extrair parâmetros
        L = float(params['L'])
        T_sea = float(params['T_sea'])
        m_dot = float(params['m_dot'])
        Cp = float(params['Cp'])
        
        # Geometria
        r_i = float(params['r_i'])
        r_1 = float(params['r_1'])
        
        # Verificar se há isolamento
        if params.get('com_isolamento', True):
            r_2 = float(params.get('r_2', r_1))
            k_insulation = float(params.get('k_insulation', 0.04))
        else:
            r_2 = r_1
            k_insulation = 0
            
        # Verificar se há jacket
        if params.get('com_jacket', False):
            r_3 = float(params.get('r_3', r_2))
            k_jacket = float(params.get('k_jacket', 0.5))
        else:
            r_3 = r_2
            k_jacket = 0
            
        # Condutividades
        k_steel = float(params['k_steel'])
        h_i = float(params['h_i'])
        h_ext = float(params['h_ext'])
        
        # 1. Cálculo das resistências
        resistances = {}
        resistances['R_conv_i'] = 1 / (h_i * 2 * self.pi * r_i)
        resistances['R_cond_pipe'] = np.log(r_1 / r_i) / (2 * self.pi * k_steel)
        
        if k_insulation > 0 and r_2 > r_1:
            resistances['R_cond_insulation'] = np.log(r_2 / r_1) / (2 * self.pi * k_insulation)
        else:
            resistances['R_cond_insulation'] = 0.0
            
        if k_jacket > 0 and r_3 > r_2:
            resistances['R_cond_jacket'] = np.log(r_3 / r_2) / (2 * self.pi * k_jacket)
        else:
            resistances['R_cond_jacket'] = 0.0
            
        resistances['R_conv_ext'] = 1 / (h_ext * 2 * self.pi * r_3)
        
        # 2. Resistência total
        R_total = sum(resistances.values())
        
        # 3. Perda térmica específica
        q_prime = (T_inlet - T_sea) / R_total
        
        # 4. Queda de temperatura
        delta_T_flowline = (q_prime * L) / (m_dot * Cp)
        
        # 5. Temperatura na saída
        T_outlet = T_inlet - delta_T_flowline
        
        # 6. Potência total perdida
        Q_total = q_prime * L / 1000
        
        # Resultados
        results = {
            'T_inlet': round(T_inlet, 2),
            'T_outlet': round(T_outlet, 2),
            'T_sea': round(T_sea, 2),
            'q_prime': round(q_prime, 1),
            'R_total': round(R_total, 4),
            'delta_T_flowline': round(delta_T_flowline, 2),
            'Q_total': round(Q_total, 1),
            'resistances': {k: round(v, 6) for k, v in resistances.items() if v > 0}
        }
        
        return results
    
    def calcular_sistema_completo(self, well_params, flowline_params):
        """Calcula o sistema completo: poço + flowline"""
        
        # 1. Cálculo do poço
        well_results = self.calcular_poço(well_params)
        
        # 2. Cálculo da flowline
        flowline_results = self.calcular_flowline(flowline_params, well_results['T_wh'])
        
        # 3. Resultados consolidados
        complete_results = {
            'well': well_results,
            'flowline': flowline_results,
            'system': {
                'T_fbh': float(well_params['T_fbh']),
                'T_wh': well_results['T_wh'],
                'T_fpso': flowline_results['T_outlet'],
                'delta_T_total': round(float(well_params['T_fbh']) - flowline_results['T_outlet'], 2),
                'delta_T_well': well_results['delta_T_well'],
                'delta_T_flowline': flowline_results['delta_T_flowline']
            }
        }
        
        return complete_results

