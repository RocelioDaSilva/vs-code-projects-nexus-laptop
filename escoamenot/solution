    def coletar_dados(self):
        """Coleta os dados da interface"""
        dados = {
            'poço': {},
            'flowline': {},
            'condições': {}
        }
        
        # Coletar dados do poço
        for param, var in self.var_poço.items():
            try:
                dados['poço'][param] = float(var.get())
            except:
                dados['poço'][param] = 0.0
        
        # Coletar dados da flowline
        for param, var in self.var_flowline.items():
            try:
                dados['flowline'][param] = float(var.get())
            except:
                dados['flowline'][param] = 0.0
        
        # Adicionar flags de isolamento
        dados['flowline']['com_isolamento'] = self.var_com_isolamento.get()
        dados['flowline']['com_jacket'] = self.var_com_jacket.get()
        
        # Coletar condições
        dados['condições']['tipo_poço'] = self.var_tipo_poço.get()
        dados['condições']['região'] = self.var_regiao.get()
        dados['condições']['tipo_fluido'] = self.var_tipo_fluido.get()
        try:
            dados['condições']['profundidade_água'] = float(self.var_profundidade_agua.get())
        except:
            dados['condições']['profundidade_água'] = 1500.0
        
        return dados
    
    def calcular_sistema(self):
        """Executa o cálculo do sistema"""
        try:
            # Coletar dados
            dados = self.coletar_dados()
            
            # Executar cálculo
            self.resultados = self.calc.calcular_sistema_completo(dados['poço'], dados['flowline'])
            
            # Adicionar condições aos resultados
            self.resultados['condições'] = dados['condições']
            
            # Atualizar interface
            self.atualizar_resultados()
            self.atualizar_graficos()
            self.atualizar_tabelas()
            self.atualizar_relatorio()
            
            # Mudar para aba de resultados
            self.notebook_resultados.set("Resultados")
            
            messagebox.showinfo("Sucesso", "Cálculo realizado com sucesso!")
            
        except Exception as e:
            messagebox.showerror("Erro", f"Erro no cálculo:\n{str(e)}")
    
