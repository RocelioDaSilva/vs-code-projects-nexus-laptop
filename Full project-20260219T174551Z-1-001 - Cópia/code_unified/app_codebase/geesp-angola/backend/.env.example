# GEESP-Angola Backend Environment Variables
# Copy this file to .env and fill in values

# API Key for endpoint authentication (leave empty to disable in dev)
GEESP_API_KEY=

# JWT secret for auth tokens (auto-generated if not set)
GEESP_JWT_SECRET=

# Database URL (defaults to SQLite)
DATABASE_URL=sqlite:///data/sqlite/geesp.db

# CORS allowed origins (comma-separated)
GEESP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# Environment: development, staging, production
GEESP_ENVIRONMENT=development

# Google Earth Engine service account (optional)
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=
