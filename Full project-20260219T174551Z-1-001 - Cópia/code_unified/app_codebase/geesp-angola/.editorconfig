# ============================================================================
# EDITORCONFIG - Consistent code style across editors
# https://editorconfig.org/
# Supported by: VS Code, PyCharm, Vim, Sublime, Emacs, and many others
# ============================================================================

root = true

# ============================================================================
# DEFAULT: All files
# ============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================================
# PYTHON FILES
# ============================================================================
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# ============================================================================
# YAML FILES
# ============================================================================
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# ============================================================================
# JSON FILES
# ============================================================================
[*.json]
indent_style = space
indent_size = 2

# ============================================================================
# MARKDOWN FILES
# ============================================================================
[*.md]
max_line_length = 120
trim_trailing_whitespace = false

# ============================================================================
# SHELL SCRIPTS
# ============================================================================
[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf

# ============================================================================
# MAKE FILES
# ============================================================================
[Makefile]
indent_style = tab
