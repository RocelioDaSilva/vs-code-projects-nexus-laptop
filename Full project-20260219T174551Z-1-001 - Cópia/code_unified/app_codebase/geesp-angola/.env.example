# =============================================================================
# GEESP-Angola Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- API ---
# API key for authentication (leave empty to allow unauthenticated access in dev)
GEESP_API_KEY=

# Comma-separated list of allowed CORS origins
GEESP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Database ---
# SQLAlchemy database URL (defaults to sqlite:///geesp.db)
DATABASE_URL=sqlite:///geesp.db
# GEESP_DATABASE_URL=postgresql://user:password@localhost:5432/geesp

# --- Google Earth Engine ---
# GEE project ID (required for geospatial features)
GEESP_GEE_PROJECT=

# --- General ---
# Application environment: development | staging | production
GEESP_ENVIRONMENT=development

# Log level: DEBUG | INFO | WARNING | ERROR
GEESP_LOG_LEVEL=INFO
