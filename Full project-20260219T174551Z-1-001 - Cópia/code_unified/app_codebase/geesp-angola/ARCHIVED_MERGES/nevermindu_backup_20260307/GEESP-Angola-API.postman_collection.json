{
  "info": {
    "_postman_id": "geesp-angola-api",
    "name": "GEESP-Angola API",
    "description": "Complete API collection for GEESP-Angola platform with authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "scenarioId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          },
          "response": []
        },
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.accessToken);",
                  "    pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "    pm.environment.set('userId', jsonData.user.id);",
                  "    console.log('✅ Registration successful');",
                  "    console.log('Access Token: ' + jsonData.accessToken.substring(0, 20) + '...');",
                  "} else {",
                  "    console.log('❌ Registration failed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"testuser@example.com\",\"password\":\"TestPassword123!\",\"confirmPassword\":\"TestPassword123!\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.accessToken);",
                  "    pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "    pm.environment.set('userId', jsonData.user.id);",
                  "    console.log('✅ Login successful');",
                  "} else {",
                  "    console.log('❌ Login failed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"testuser@example.com\",\"password\":\"TestPassword123!\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile"]
            }
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"newemail@example.com\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile"]
            }
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"password\":\"TestPassword123!\",\"newPassword\":\"NewPassword456!\",\"confirmNewPassword\":\"NewPassword456!\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "change-password"]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Scenarios",
      "item": [
        {
          "name": "Create Scenario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('scenarioId', jsonData.id);",
                  "    console.log('✅ Scenario created: ' + jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Test Scenario 2026\",\"description\":\"Testing GEESP algorithm\",\"weights\":{\"climate\":0.3,\"soil\":0.25,\"terrain\":0.25,\"infrastructure\":0.2},\"solar_params\":{\"wattage\":100,\"efficiency\":0.18,\"lifetime\":25,\"omCost\":500,\"capitalCost\":5000},\"tags\":[\"huila\",\"test\",\"2026\"]}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/scenarios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "scenarios"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Scenarios",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/scenarios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "scenarios"]
            }
          },
          "response": []
        },
        {
          "name": "Get Scenario by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/scenarios/{{scenarioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "scenarios", "{{scenarioId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Scenario",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/scenarios/{{scenarioId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "scenarios", "{{scenarioId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Financial Analysis",
      "item": [
        {
          "name": "Calculate Financial Metrics",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"ghi\":5.5,\"areaM2\":100,\"solarParams\":{\"wattage\":100,\"efficiency\":0.18,\"lifetime\":25,\"omCost\":500,\"capitalCost\":5000}}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/calculate-financial-metrics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "calculate-financial-metrics"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analysis",
      "item": [
        {
          "name": "Filter Communities",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"scenario_id\":\"{{scenarioId}}\",\"suitability_min\":60,\"lcoe_max\":0.50}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/filter-communities",
              "host": ["{{baseUrl}}"],
              "path": ["api", "filter-communities"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
