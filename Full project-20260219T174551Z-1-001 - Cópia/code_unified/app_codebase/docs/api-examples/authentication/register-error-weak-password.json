{
  "endpoint": "POST /api/auth/register",
  "description": "Registration error - password too weak",
  "method": "POST",
  "url": "http://localhost:3000/api/auth/register",
  "summary": "Failed registration due to weak password",
  
  "request": {
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "email": "user@example.com",
      "password": "weak",
      "confirmPassword": "weak"
    }
  },
  
  "response": {
    "status": 400,
    "statusText": "Bad Request",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "success": false,
      "error": "VALIDATION_ERROR",
      "message": "Password does not meet strength requirements",
      "details": {
        "score": 15,
        "feedback": [
          "Password is too short (minimum 8 characters)",
          "Password must contain an uppercase letter",
          "Password must contain a number",
          "Password must contain a special character (!@#$%^&*)"
        ]
      }
    }
  },
  
  "notes": [
    "HTTP 400 returned for validation errors",
    "Check 'feedback' array for specific requirements not met",
    "Score 0-100 indicates password strength: 0-30=Weak, 31-60=Fair, 61-80=Good, 81-100=Strong",
    "Passwords MUST have: 8+ chars, uppercase, lowercase, number, special char"
  ]
}
