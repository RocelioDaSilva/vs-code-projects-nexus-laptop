  .clamp(0, 1)
  .rename('simple_suitability_score');

// ---------------------------------------------------------------------
// 7.4c INTERACTIVE CATEGORY-BASED SUITABILITY (single main layer)
// ---------------------------------------------------------------------
// This image is what the main heatmap layer will display, controlled
// by UI toggles for the 4 big categories: Weather, Land, Infra, Socio.
var interactiveSuitability = comprehensiveSuitability.rename('interactive_suitability');

// Default category weights for interactive combination
var interactiveCategoryWeights = {
  weather: 0.35,
  land: 0.25,
  infra: 0.25,
  socio: 0.15
};

// Recompute interactiveSuitability based on which categories are enabled.
function recomputeInteractiveSuitability(options) {
  options = options || {};

  var img = ee.Image(0);
  var weightSum = 0;

  if (options.weather) {
    img = img.add(weatherSuitability.multiply(interactiveCategoryWeights.weather));
    weightSum += interactiveCategoryWeights.weather;
  }
  if (options.land) {
    img = img.add(landSuitability.multiply(interactiveCategoryWeights.land));
    weightSum += interactiveCategoryWeights.land;
  }
  if (options.infra) {
    img = img.add(infrastructureSuitability.multiply(interactiveCategoryWeights.infra));
    weightSum += interactiveCategoryWeights.infra;
  }
  if (options.socio) {
    img = img.add(comprehensiveSocioEconomicScore.multiply(interactiveCategoryWeights.socio));
    weightSum += interactiveCategoryWeights.socio;
  }

  // Avoid division by zero: if tudo desligado, devolve imagem zero.
  var combined = ee.Algorithms.If(
    ee.Number(weightSum).gt(0),
    img.divide(weightSum)
      .multiply(angolaRegionalAdjustment)
      .multiply(hardConstraints)
      .clamp(0, 1),
    ee.Image(0).rename('interactive_suitability')
  );

  interactiveSuitability = ee.Image(combined).rename('interactive_suitability');

  // Atualizar a layer principal de heatmap no mapa
  Map.layers().forEach(function(layer) {
    if (layer.getName() === '7.6 Comprehensive Suitability Heatmap') {
      layer.setEeObject(interactiveSuitability);
    }
  });
}

// ----- 7.5 DYNAMIC WEIGHTS -----
var projectType = 0.5; // 0 = off-grid, 1 = grid-connected utility
var dynamicWeights = {
  solarResource: 0.18 + (projectType * 0.04),
  landSuitable: 0.12,
  gentleSlope: 0.08 - (projectType * 0.02),
  floodSafe: 0.08,
  fireSafe: 0.05,
  aspectFavorable: 0.04 + ((1-projectType) * 0.02),
  soilStable: 0.06 + (projectType * 0.02),
  roadAccessible: 0.05 + ((1-projectType) * 0.03),
  gridProximity: 0.03 + (projectType * 0.04),
  waterAvailable: 0.02 + ((1-projectType) * 0.02),
  communityNeed: 0.08,
  regulatoryScore: 0.03,
  angolaRegional: 0.05
};

// ----- 7.6 FINAL SUITABILITY SCORE -----
var constrainedSolarResource = enhancedSolarResource.multiply(hardConstraints);

var suitabilityScore = constrainedSolarResource.multiply(dynamicWeights.solarResource)
    .add(soilSuitabilityScore.multiply(dynamicWeights.soilStable))
    .add(slopeScore.multiply(dynamicWeights.gentleSlope))
    .add(aspectScore.multiply(dynamicWeights.aspectFavorable))
    .add(floodSafety.multiply(dynamicWeights.floodSafe))
    .add(fireRiskScore.multiply(dynamicWeights.fireSafe))
    .add(roadAccessScore.multiply(dynamicWeights.roadAccessible))
    .add(gridConnectionScore.multiply(dynamicWeights.gridProximity))
    .add(waterAccessScore.multiply(dynamicWeights.waterAvailable))
    .add(energyNeedIndex.multiply(dynamicWeights.communityNeed))
    .add(compositeRegulatoryScore.multiply(dynamicWeights.regulatoryScore))
    // Add coastal corrosion risk capability (small positive weight; also enforced via constraints indirectly)
    .add(coastScore.multiply(0.03))
    .multiply(angolaRegionalAdjustment.pow(dynamicWeights.angolaRegional))
    .multiply(hardConstraints)
    .pow(1.2) // Non-linear scaling
    .clamp(0, 1)
    .clip(STUDY_AREA.country)
    .rename('final_suitability_score');

// ----- 7.7 RELIABILITY SCORE -----
var dataQuality = solarConsistency
    .multiply(floodSafety.gt(0.7))
    .multiply(soilSuitabilityScore.gt(0.6));
var reliabilityScore = suitabilityScore.multiply(dataQuality).rename('reliable_suitability_score');

