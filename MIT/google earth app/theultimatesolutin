// =====================================================================
// 📍 SECTION 1: STUDY AREA & CONFIGURATION
// =====================================================================

/**
 * Define the study area and global configuration parameters
 * Angola country boundary and administrative divisions
 */
var STUDY_AREA = {
  country: ee.FeatureCollection('FAO/GAUL/2015/level0')
              .filter(ee.Filter.eq('ADM0_NAME', 'Angola')),
  provinces: ee.FeatureCollection('FAO/GAUL/2015/level1')
                .filter(ee.Filter.eq('ADM0_NAME', 'Angola'))
};

// Global configuration object with latest available data ranges
var CONFIG = {
  // Data source time ranges (optimized for 2024-2025 analysis)
  dataSources: {
    solar: ['2023-01-01', '2025-12-31'],        // ERA5-Land (latest available)
    weather: ['2023-01-01', '2025-12-31'],      // ERA5-Land
    aerosol: ['2023-01-01', '2025-12-31'],      // MODIS
    vegetation: ['2023-01-01', '2025-12-31'],   // MODIS
    nightlights: ['2023-01-01', '2025-12-31'],  // VIIRS
    population: 2020                             // WorldPop (latest available)
  },

  // Analysis parameters
  analysis: {
    scale: 1000,           // meters
    maxPixels: 1e9,
    defaultThreshold: 0.7
  },

  // UI styling
  ui: {
    primaryColor: '#FF9800',
    secondaryColor: '#4CAF50',
    accentColor: '#2196F3'
  }
};

// Initialize map view
Map.centerObject(STUDY_AREA.country, 6);
Map.addLayer(STUDY_AREA.country,
             {color: 'black', width: 2},
             '🇦🇴 Angola Boundary',
             true);

// Global simplification constants for performance
// Coarser distance-transform resolution to speed up heavy operations.
var DIST_SCALE = CONFIG.analysis.scale * 2; // e.g., 2000 m when analysis.scale = 1000

/**
 * Helper: compute Euclidean distance (in km) from a binary mask,
 * using a coarser internal resolution to reduce computation cost.
 */
function computeDistanceKm(mask) {
  var coarse = mask
    .unmask(0)
    .reproject({crs: 'EPSG:4326', scale: DIST_SCALE});

  return coarse.fastDistanceTransform()
    .sqrt()
    .multiply(DIST_SCALE / 1000.0); // pixels -> meters -> km
}

// =====================================================================
// ☀️ SECTION 2: ADVANCED SOLAR RESOURCE ANALYSIS
// =====================================================================

/**
 * Load and process high-resolution solar irradiance data
 * Uses ERA5-Land for the most recent available data (2023-2025)
 */
print('🔄 Loading solar irradiance data...');

// Global Horizontal Irradiance (GHI) - primary solar metric
// Use DAILY_AGGR instead of HOURLY for much faster processing while
// preserving representative solar resource statistics.
var solarData = {
  ghi: ee.ImageCollection('ECMWF/ERA5_LAND/DAILY_AGGR')
    .filterDate(CONFIG.dataSources.solar[0], CONFIG.dataSources.solar[1])
    .select('surface_solar_radiation_downwards_sum')
    .mean()
    .divide(3600000) // Convert J/m² to kWh/m²/day
    .clip(STUDY_AREA.country)
    .rename('GHI'),

  // (Zenith angle band not available in ERA5-Land; DNI will be estimated
  // from GHI only using an empirical relationship without zenith correction.)
  zenith: null
};

// Calculate Direct Normal Irradiance (DNI) and Diffuse Horizontal Irradiance (DHI)
var irradianceCalculations = {
  // Clearness index (normalized GHI) - using theoretical maximum for Angola
  clearnessIndex: solarData.ghi.divide(8.5), // Approximate max GHI for Angola region

  // DNI fraction using empirical relationship with zenith angle correction
  dniFraction: null,

  // Final DNI and DHI values
  dni: null,
  dhi: null
};

// Calculate DNI fraction (empirical relationship, no zenith correction)
irradianceCalculations.dniFraction = irradianceCalculations.clearnessIndex
  .multiply(0.8).add(0.2); // Base empirical relationship

// Calculate final DNI and DHI
irradianceCalculations.dni = solarData.ghi
  .multiply(irradianceCalculations.dniFraction)
  .clamp(0, 10) // Maximum reasonable DNI value (kWh/m²/day)
  .rename('DNI');

irradianceCalculations.dhi = solarData.ghi
  .subtract(irradianceCalculations.dni)
  .clamp(0, 10) // Maximum reasonable DHI value (kWh/m²/day)
  .rename('DHI');

// Extract final values for easier reference
var ghi = solarData.ghi;
var dni = irradianceCalculations.dni;
var dhi = irradianceCalculations.dhi;

// ---------------------------------------------------------------------
// OPTIONAL (FAST) ALTERNATE SOLAR SOURCE: DAYMET LONG-TERM GHI
// - Adds the capability from your reference script.
// - Useful as a comparison layer or fallback.
// NOTE: DAYMET is primarily North America; for Angola it may be empty.
// We keep it optional and non-blocking.
var daymetGhi = ee.ImageCollection('NASA/ORNL/DAYMET_V4')
  .filterDate('2000-01-01', '2020-12-31')
  .select('srad')
  .mean()
  .multiply(0.024) // W/m² (daily avg) -> kWh/m²/day
  .clip(STUDY_AREA.country)
  .rename('GHI_DAYMET');

Map.addLayer(daymetGhi, {min: 4.0, max: 6.0, palette: ['blue', 'yellow', 'orange', 'red']},
  '2.0 (Optional) DAYMET GHI (kWh/m²/day)', false);

/**
 * Analyze solar variability and stability
 * Critical for reliable solar energy production
 */
print('🔄 Analyzing solar variability...');

var solarVariability = {
  // Hourly to daily conversion
  // Use DAILY_AGGR solar radiation sums for variability to reduce computation.
  hourly: ee.ImageCollection('ECMWF/ERA5_LAND/DAILY_AGGR')
    .filterDate(CONFIG.dataSources.solar[0], CONFIG.dataSources.solar[1])
    .select('surface_solar_radiation_downwards_sum'),

  // Daily aggregated data
  daily: null,

  // Statistical measures
  mean: null,
  stdDev: null,
  coefficientOfVariation: null,

  // Stability score (0-1, higher = more stable)
  stabilityScore: null
};

// Convert collection to a representative daily image
// (mean of daily sums across the study period).
solarVariability.daily = solarVariability.hourly
  .select('surface_solar_radiation_downwards_sum')
  .mean()
  .divide(3600000); // kWh/m²/day

// Calculate statistical measures (across time)
// Here, "daily" is already a mean image; we treat it as the mean resource level.
solarVariability.mean = solarVariability.daily;
// Standard deviation over time, using the hourly collection as a proxy
solarVariability.stdDev = solarVariability.hourly.reduce(ee.Reducer.stdDev());
solarVariability.coefficientOfVariation = solarVariability.stdDev
  .divide(solarVariability.mean.add(0.1))
  .rename('solar_coefficient_of_variation');

// Solar stability score (lower CV = more stable = higher score)
solarVariability.stabilityScore = ee.Image(1)
  .subtract(solarVariability.coefficientOfVariation.unitScale(0, 0.5))
  .clamp(0, 1)
  .rename('solar_stability');

// Extract for global use
var solarStability = solarVariability.stabilityScore;

// ----- 2.3 ENHANCED ATMOSPHERIC & WEATHER ANALYSIS -----
print('Processing atmospheric data...');

// Temperature with seasonal analysis
var temperature = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('temperature_2m')
  .mean()
  .subtract(273.15) // Convert K to C
  .clip(STUDY_AREA.country)
  .rename('temperature');

// Temperature variability (diurnal and seasonal)
var tempDailyMax = ee.ImageCollection('ECMWF/ERA5_LAND/DAILY_AGGR')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('temperature_2m_max')
  .mean()
  .subtract(273.15)
  .clip(STUDY_AREA.country);

var tempDailyMin = ee.ImageCollection('ECMWF/ERA5_LAND/DAILY_AGGR')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('temperature_2m_min')
  .mean()
  .subtract(273.15)
  .clip(STUDY_AREA.country);

var tempRange = tempDailyMax.subtract(tempDailyMin).rename('temperature_range');

// Improved temperature efficiency penalty (PVs degrade faster at high temps)
var tempEfficiency = temperature.multiply(-0.0045).add(1.0).clamp(0.75, 1.0).rename('temp_efficiency');

// Wind speed and direction analysis
var windU = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('u_component_of_wind_10m')
  .mean()
  .clip(STUDY_AREA.country);

var windV = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('v_component_of_wind_10m')
  .mean()
  .clip(STUDY_AREA.country);

var windSpeed = windU.pow(2).add(windV.pow(2)).sqrt().rename('wind_speed');
var windDirection = windV.atan2(windU).multiply(180).divide(Math.PI).add(180).rename('wind_direction');

// Wind cooling benefit (optimal wind speeds: 1-3 m/s for cooling without turbulence)
var windCooling = windSpeed.subtract(2).abs().multiply(-0.15).add(1).clamp(0.85, 1.1).rename('wind_cooling');

// Humidity and precipitation analysis
var humidity = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('dewpoint_temperature_2m')
  .mean()
  .subtract(273.15)
  .clip(STUDY_AREA.country)
  .rename('dewpoint');

var relativeHumidity = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('relative_humidity_2m')
  .mean()
  .clip(STUDY_AREA.country)
  .rename('relative_humidity');

// Precipitation analysis (annual total and seasonality)
var precipitation = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
  .filterDate(CONFIG.dataSources.weather[0], CONFIG.dataSources.weather[1])
  .select('total_precipitation_hourly')
  .sum()
  .multiply(1000) // Convert m to mm
  .clip(STUDY_AREA.country)
  .rename('annual_precipitation');

// Precipitation cleaning benefit (moderate rain helps, too much causes issues)
var precipCleaning = precipitation.subtract(500).abs().multiply(-0.0004).add(1).clamp(0.8, 1.1).rename('precip_cleaning');

/**
 * Advanced aerosol and dust analysis
 * Critical for solar energy production in desert regions like Angola
 */
print('🔄 Analyzing aerosol and dust data...');

var aerosolAnalysis = {
  // Aerosol optical depth from MODIS (higher values = more atmospheric particles)
  opticalDepth: ee.ImageCollection('MODIS/061/MCD19A2_GRANULES')
    .filterDate(CONFIG.dataSources.aerosol[0], CONFIG.dataSources.aerosol[1])
    .select('Optical_Depth_047')
    .mean()
    .clip(STUDY_AREA.country)
    .rename('aerosol_optical_depth'),

  // Dust transmission score (lower AOD = better transmission = higher score)
  dustTransmission: null,

  // Overall atmospheric clarity score
  atmosphericClarity: null
};

// Calculate dust transmission efficiency
aerosolAnalysis.dustTransmission = aerosolAnalysis.opticalDepth
  .multiply(-0.6).add(1)  // 60% reduction per unit AOD
  .clamp(0.6, 1.0)       // Minimum 60% transmission
  .rename('dust_transmission');

// Atmospheric clarity combines multiple factors
aerosolAnalysis.atmosphericClarity = aerosolAnalysis.dustTransmission;

// Extract for global use
var aerosol = aerosolAnalysis.opticalDepth;
var dustScore = aerosolAnalysis.dustTransmission;

/**
 * Calculate comprehensive solar resource score
 * Combines all solar-related factors into a single suitability metric
 */
print('🔄 Calculating comprehensive solar resource score...');

var solarResourceWeights = {
  ghi: 0.35,           // Global Horizontal Irradiance (35%)
  dni: 0.25,           // Direct Normal Irradiance (25%)
  stability: 0.15,     // Solar stability/variability (15%)
  tempEfficiency: 0.10, // Temperature efficiency penalty (10%)
  windCooling: 0.08,   // Wind cooling benefit (8%)
  dustTransmission: 0.07 // Atmospheric clarity (7%)
};

// Normalize and combine all solar factors
var ghiNorm = ghi.unitScale(4.0, 7.0).clamp(0, 1);
var dniNorm = dni.unitScale(3.0, 6.0).clamp(0, 1);

var comprehensiveSolarScore = ghiNorm.multiply(solarResourceWeights.ghi)
  .add(dniNorm.multiply(solarResourceWeights.dni))
  .add(solarStability.multiply(solarResourceWeights.stability))
  .add(tempEfficiency.multiply(solarResourceWeights.tempEfficiency))
  .add(windCooling.multiply(solarResourceWeights.windCooling))
  .add(dustScore.multiply(solarResourceWeights.dustTransmission))
  .clamp(0, 1)
  .rename('comprehensive_solar_score');

// Add solar visualization layers
Map.addLayer(ghi, {min: 4.5, max: 6.5, palette: ['blue', 'cyan', 'yellow', 'orange', 'red']}, '2.1 GHI (kWh/m²/day)', false);
Map.addLayer(dni, {min: 3.5, max: 5.5, palette: ['blue', 'cyan', 'green', 'yellow', 'orange']}, '2.2 DNI (kWh/m²/day)', false);
Map.addLayer(solarStability, {min: 0, max: 1, palette: ['red', 'orange', 'yellow', 'green']}, '2.3 Solar Stability', false);
Map.addLayer(comprehensiveSolarScore, {min: 0, max: 1, palette: ['darkred', 'red', 'orange', 'yellow', 'lime', 'green']}, '2.4 Comprehensive Solar Score', true);

// --------------------------
// 3. ADVANCED TERRAIN & ENVIRONMENTAL ANALYSIS
// --------------------------

// ----- 3.1 HIGH-RESOLUTION TERRAIN ANALYSIS -----
print('Analyzing terrain characteristics...');

// Use NASADEM for higher resolution elevation data
var elevation = ee.Image('NASA/NASADEM_HGT/001').select('elevation').clip(STUDY_AREA.country);
var slope = ee.Terrain.slope(elevation);
var aspect = ee.Terrain.aspect(elevation);
var hillshade = ee.Terrain.hillshade(elevation);

// Advanced slope analysis (optimal slope: 0-10 degrees for solar)
var slopeScore = slope.multiply(-0.1).add(1).clamp(0.1, 1).rename('slope_score');

// Enhanced aspect analysis for Southern Hemisphere
// South-facing (180°) is optimal, with tolerance for SE/SW (135-225°)
var aspectDeviation = aspect.subtract(180).abs();
var aspectScore = aspectDeviation.multiply(-0.0222).add(1).clamp(0.2, 1).rename('aspect_score');

// Terrain roughness (TPI - Topographic Position Index)
var kernel = ee.Kernel.square({radius: 5, units: 'pixels'});
var meanElevation = elevation.focalMean({kernel: kernel, iterations: 1});
var tpi = elevation.subtract(meanElevation).rename('terrain_position_index');

// Terrain complexity score (lower complexity = better for construction)
var terrainComplexity = tpi.abs().multiply(-0.02).add(1).clamp(0.3, 1).rename('terrain_complexity_score');

// Elevation-based corrections
var elevationScore = elevation.divide(2000).clamp(0.8, 1.2).rename('elevation_score');

// ----- 3.2 ADVANCED SOIL ANALYSIS -----
print('Analyzing soil properties...');

// Enhanced soil data from ISRIC SoilGrids
var soilClay = ee.Image('projects/soilgrids-isric/clay_mean')
                .select('clay_0-5cm_mean')
                .clip(STUDY_AREA.country).divide(10).rename('clay_content');
var soilSand = ee.Image('projects/soilgrids-isric/sand_mean')
                .select('sand_0-5cm_mean')
                .clip(STUDY_AREA.country).divide(10).rename('sand_content');
var soilSilt = ee.Image('projects/soilgrids-isric/silt_mean')
                .select('silt_0-5cm_mean')
                .clip(STUDY_AREA.country).divide(10).rename('silt_content');
var soilBulkDensity = ee.Image('projects/soilgrids-isric/bdod_mean')
                      .select('bdod_0-5cm_mean')
                      .clip(STUDY_AREA.country).divide(100).rename('bulk_density');
var soilOrganicCarbon = ee.Image('projects/soilgrids-isric/soc_mean')
                        .select('soc_0-5cm_mean')
                        .clip(STUDY_AREA.country).divide(100).rename('organic_carbon');

// Soil texture classification and scoring
var clayScore = soilClay.subtract(30).abs().multiply(-0.0333).add(1).clamp(0.4, 1);
var sandScore = soilSand.subtract(40).abs().multiply(-0.025).add(1).clamp(0.5, 1);
var bulkDensityScore = soilBulkDensity.unitScale(1.1, 1.9).clamp(0.6, 1);

// Comprehensive soil suitability score
var soilSuitabilityScore = clayScore.multiply(0.3)
                          .add(sandScore.multiply(0.3))
                          .add(bulkDensityScore.multiply(0.4))
                          .clamp(0.4, 1)
                          .rename('soil_suitability_score');

// Alias for backward-compatibility with older variable name
var soilStabilityScore = soilSuitabilityScore;

// ----- 3.3 ADVANCED HYDROLOGY & FLOOD ANALYSIS -----
print('Analyzing hydrological conditions...');

// Enhanced flood risk using multiple data sources
var waterOccurrence = ee.Image('JRC/GSW1_4/GlobalSurfaceWater')
                      .select('occurrence')
                      .clip(STUDY_AREA.country);
var waterRecurrence = ee.Image('JRC/GSW1_4/GlobalSurfaceWater')
                      .select('recurrence')
                      .clip(STUDY_AREA.country);

// Multi-temporal flood risk assessment
var floodRisk = waterOccurrence.divide(100).multiply(waterRecurrence.divide(10)).rename('flood_risk');
var floodSafety = ee.Image(1).subtract(floodRisk).clamp(0.3, 1).rename('flood_safety');

// Seasonal water availability
var seasonalWater = ee.Image('JRC/GSW1_4/GlobalSurfaceWater')
                    .select('seasonality')
                    .clip(STUDY_AREA.country);
var waterSeasonalityScore = seasonalWater.divide(12).clamp(0.5, 1).rename('water_seasonality_score');

// ----- 3.4 VEGETATION & BIOMASS ANALYSIS -----
print('Analyzing vegetation and biomass...');

// Recent vegetation data
var ndvi = ee.ImageCollection('MODIS/061/MOD13Q1')
           .filterDate(CONFIG.dataSources.vegetation[0], CONFIG.dataSources.vegetation[1])
           .select('NDVI')
           .mean()
           .multiply(0.0001)
           .clip(STUDY_AREA.country)
           .rename('NDVI');

// Enhanced vegetation indices
var evi = ee.ImageCollection('MODIS/061/MOD13Q1')
          .filterDate(CONFIG.dataSources.vegetation[0], CONFIG.dataSources.vegetation[1])
          .select('EVI')
          .mean()
          .multiply(0.0001)
          .clip(STUDY_AREA.country)
          .rename('EVI');

// Vegetation density and type classification
var vegetationDensity = ndvi.multiply(2.5).clamp(0, 1).rename('vegetation_density');

// Fire risk analysis with recent data
var fireCollection = ee.ImageCollection('MODIS/061/MCD64A1')
                      .filterDate('2015-01-01', '2024-12-31')
                      .filterBounds(STUDY_AREA.country)
                      .select('BurnDate');
var fireCount = fireCollection.count().clip(STUDY_AREA.country);
var fireFrequency = fireCount.divide(10).rename('annual_fire_frequency');

// Enhanced fire risk scoring
var fireRiskScore = fireFrequency.multiply(-2).add(1).clamp(0.2, 1).rename('fire_risk_score');

// Land cover analysis for solar suitability
var landCover = ee.ImageCollection('ESA/WorldCover/v200').first().select('Map').clip(STUDY_AREA.country);

// Alternative: Try Dynamic World for more recent land cover if available
try {
  var dynamicWorld = ee.ImageCollection('GOOGLE/DYNAMICWORLD/V1')
                      .filterDate('2023-01-01', '2024-12-31')
                      .filterBounds(STUDY_AREA.country)
                      .select('label')
                      .mode()
                      .clip(STUDY_AREA.country);
  landCover = dynamicWorld.rename('Map'); // Use Dynamic World if available
  print('Using Google Dynamic World land cover (2023-2024 data)');
} catch (e) {
  print('Using ESA WorldCover v200 (2020-2021 data)');
}

// Land cover suitability for solar
var landCoverScore = ee.Image(0.5)
    .where(landCover.eq(10), 0.2)   // Tree cover - poor for solar
    .where(landCover.eq(20), 0.7)   // Shrubland - moderate
    .where(landCover.eq(30), 0.8)   // Grassland - good
    .where(landCover.eq(40), 0.4)   // Cropland - variable
    .where(landCover.eq(50), 0.1)   // Built-up - poor
    .where(landCover.eq(60), 0.9)   // Bare/sparse vegetation - excellent
    .where(landCover.eq(80), 0.0)   // Permanent water bodies - unsuitable
    .where(landCover.eq(95), 0.3)   // Mangroves - poor
    .rename('land_cover_suitability');

// ---------------------------------------------------------------------
// CAPABILITY: SIMPLE LAND-COVER EXCLUSION MASK (from your reference script)
// Exclude: Tree cover (10), Cropland (40), Built-up (50), Water (80), Mangroves (95)
var unsuitableLand = landCover.eq(10)
  .or(landCover.eq(40))
  .or(landCover.eq(50))
  .or(landCover.eq(80))
  .or(landCover.eq(95));
var landSuitabilityMask = unsuitableLand.not().rename('land_suitable_mask');
Map.addLayer(landSuitabilityMask, {min: 0, max: 1, palette: ['red', 'green']},
  '3.X Land Suitability Mask (Exclusions)', false);

// ---------------------------------------------------------------------
// CAPABILITY: COASTAL DISTANCE / CORROSION RISK SCORE (from your reference script)
// Fast approximation using a global water mask and euclidean distance.
// (Score = 1 for areas >= 50km from coast/water, otherwise scaled 0..1)
var waterMask = ee.ImageCollection('MODIS/006/MOD44W')
  .filterDate('2015-01-01', '2015-12-31')
  .first()
  .select('water_mask')
  .clip(STUDY_AREA.country);

var distanceToCoastKm = waterMask
  .distance(ee.Kernel.euclidean(127500, 'meters'))
  .divide(1000)
  .rename('distance_to_coast_km');

var coastScore = distanceToCoastKm.divide(50).min(1.0).rename('coast_score');

Map.addLayer(distanceToCoastKm, {min: 0, max: 200, palette: ['darkblue', 'lightblue', 'white']},
  '3.X Distance to Coast/Water (km)', false);
Map.addLayer(coastScore, {min: 0, max: 1, palette: ['red', 'yellow', 'green']},
  '3.X Coast Safety Score (>=50km best)', false);

// ----- 3.5 COMPREHENSIVE ENVIRONMENTAL SCORE -----
print('Calculating environmental suitability...');

var environmentalWeights = {
  slope: 0.20,
  aspect: 0.15,
  terrainComplexity: 0.10,
  elevation: 0.05,
  soilSuitability: 0.20,
  floodSafety: 0.15,
  vegetationDensity: 0.10,
  fireRisk: 0.05
};

var comprehensiveEnvironmentalScore = slopeScore.multiply(environmentalWeights.slope)
  .add(aspectScore.multiply(environmentalWeights.aspect))
  .add(terrainComplexity.multiply(environmentalWeights.terrainComplexity))
  .add(elevationScore.multiply(environmentalWeights.elevation))
  .add(soilSuitabilityScore.multiply(environmentalWeights.soilSuitability))
  .add(floodSafety.multiply(environmentalWeights.floodSafety))
  .add(ee.Image(1).subtract(vegetationDensity).multiply(environmentalWeights.vegetationDensity))
  .add(fireRiskScore.multiply(environmentalWeights.fireRisk))
  .clamp(0, 1)
  .rename('comprehensive_environmental_score');

// Add environmental visualization layers
Map.addLayer(slopeScore, {min: 0.1, max: 1, palette: ['red', 'orange', 'yellow', 'green']}, '3.1 Slope Suitability', false);
Map.addLayer(aspectScore, {min: 0.2, max: 1, palette: ['red', 'orange', 'yellow', 'green']}, '3.2 Aspect Suitability', false);
Map.addLayer(soilSuitabilityScore, {min: 0.4, max: 1, palette: ['brown', 'tan', 'yellow', 'green']}, '3.3 Soil Suitability', false);
Map.addLayer(floodSafety, {min: 0.3, max: 1, palette: ['blue', 'cyan', 'white', 'yellow', 'brown']}, '3.4 Flood Safety', false);
Map.addLayer(landCoverScore, {min: 0, max: 1, palette: ['red', 'orange', 'yellow', 'lime', 'green']}, '3.5 Land Cover Suitability', false);
Map.addLayer(comprehensiveEnvironmentalScore, {min: 0, max: 1, palette: ['darkred', 'red', 'orange', 'yellow', 'lime', 'green']}, '3.6 Comprehensive Environmental Score', false);

// ----- 3.4 VEGETATION & FIRE RISK -----
