// Create interactive panel for layer controls and project type selection
var createControlPanel = function() {
  var panel = ui.Panel({
    style: {
      position: 'bottom-right',
      width: '300px',
      padding: '10px'
    }
  });

  // Title
  panel.add(ui.Label({
    value: 'Advanced Controls',
    style: {fontSize: '16px', fontWeight: 'bold', margin: '0 0 10px 0'}
  }));

  // Project type selector
  panel.add(ui.Label('Project Type:', {fontWeight: 'bold'}));

  var projectTypeSelect = ui.Select({
    items: [
      {label: 'Utility Scale (Large)', value: 'utility'},
      {label: 'Commercial/Industrial', value: 'commercial'},
      {label: 'Distributed/Residential', value: 'distributed'}
    ],
    value: 'utility',
    onChange: function(value) {
      // Update weights based on project type
      var weights = {
        utility: {weather: 0.4, land: 0.3, infra: 0.3},
        commercial: {weather: 0.5, land: 0.2, infra: 0.3},
        distributed: {weather: 0.3, land: 0.4, infra: 0.3}
      };

      var selectedWeights = weights[value];

      // Recalculate comprehensive suitability with new weights
      var newComprehensive = weatherSuitability.multiply(selectedWeights.weather)
        .add(landSuitability.multiply(selectedWeights.land))
        .add(infrastructureSuitability.multiply(selectedWeights.infra));

      comprehensiveSuitability = newComprehensive;

      // Update the map layer
      Map.layers().forEach(function(layer) {
        if (layer.getName() === '7.6 Comprehensive Suitability Heatmap') {
          layer.setEeObject(newComprehensive);
        }
      });

      print('Updated weights for ' + value + ' project type: Weather=' +
            selectedWeights.weather + ', Land=' + selectedWeights.land +
            ', Infrastructure=' + selectedWeights.infra);
    }
  });
  panel.add(projectTypeSelect);

  // Layer opacity controls
  panel.add(ui.Label('Layer Opacity:', {fontWeight: 'bold', margin: '10px 0 5px 0'}));

  var opacitySlider = ui.Slider({
    min: 0,
    max: 1,
    step: 0.1,
    value: 1.0,
    style: {width: '250px'}
  });

  opacitySlider.onChange(function(value) {
    Map.layers().forEach(function(layer) {
      if (layer.getName().indexOf('7.') === 0) {  // Only affect main suitability layers
        layer.setOpacity(value);
      }
    });
    print('Layer opacity set to:', value);
  });

  panel.add(ui.Label('Transparency'));
  panel.add(opacitySlider);
  panel.add(ui.Label('Opaque'));

  return panel;
};

