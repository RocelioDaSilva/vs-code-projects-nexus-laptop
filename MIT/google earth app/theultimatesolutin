// Function to dynamically update layered suitability
function updateLayeredSuitability() {
  var baseScore = ee.Image(0);
  var layerCount = 0;

  // Always include weather
  baseScore = baseScore.add(weatherSuitability);
  layerCount += 1;

  // Add land if toggled (for now, we'll assume it's included)
  baseScore = baseScore.add(landSuitability.multiply(0.4));
  layerCount += 0.4;

  // Add infrastructure if toggled
  baseScore = baseScore.add(infrastructureSuitability.multiply(0.3));
  layerCount += 0.3;

  // Normalize by layer count and apply constraints
  layeredSuitability = baseScore.divide(layerCount)
    .multiply(angolaRegionalAdjustment)
    .multiply(hardConstraints)
    .clamp(0, 1);

