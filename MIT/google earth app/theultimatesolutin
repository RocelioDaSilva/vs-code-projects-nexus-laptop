/**
 * Calculate comprehensive model validation metrics
 * Provides statistical analysis of the suitability results
 */
var calculateValidationMetrics = function() {
  print('🔍 Calculating model validation metrics...');

  // Calculate area statistics
  var totalArea = STUDY_AREA.country.geometry().area().divide(1e6); // km²
  var suitableAreaHigh = comprehensiveSuitability.gt(0.7).multiply(ee.Image.pixelArea()).reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: STUDY_AREA.country,
    // Use coarser scale for faster validation statistics.
    scale: 3000,
    maxPixels: 1e13
  }).get('area');

  suitableAreaHigh = ee.Number(suitableAreaHigh).divide(1e6); // km²
  var suitabilityPercentHigh = suitableAreaHigh.divide(totalArea).multiply(100);

  var suitableAreaExcellent = comprehensiveSuitability.gt(0.8).multiply(ee.Image.pixelArea()).reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: STUDY_AREA.country,
    scale: 3000,
    maxPixels: 1e13
  }).get('area');

  suitableAreaExcellent = ee.Number(suitableAreaExcellent).divide(1e6); // km²
  var suitabilityPercentExcellent = suitableAreaExcellent.divide(totalArea).multiply(100);

  print('📊 === MODEL VALIDATION METRICS ===');
  print('🗺️ Total Angola Area: ' + totalArea.format('%.0f') + ' km²');
  print('🎯 High Suitability Area (>0.7): ' + suitableAreaHigh.format('%.0f') + ' km² (' + suitabilityPercentHigh.format('%.1f') + '%)');
  print('⭐ Excellent Suitability Area (>0.8): ' + suitableAreaExcellent.format('%.0f') + ' km² (' + suitabilityPercentExcellent.format('%.1f') + '%)');

  // Distribution statistics
  var histogram = comprehensiveSuitability.reduceRegion({
    reducer: ee.Reducer.histogram(20),
    geometry: STUDY_AREA.country,
    scale: 3000,
    maxPixels: 1e13
  });

  print('📈 Suitability Score Distribution:');
  print(histogram);

  // Performance metrics
  var meanSuitability = comprehensiveSuitability.reduceRegion({
    reducer: ee.Reducer.mean(),
    geometry: STUDY_AREA.country,
    scale: 3000,
    maxPixels: 1e13
  }).get('constant');

  var stdDevSuitability = comprehensiveSuitability.reduceRegion({
    reducer: ee.Reducer.stdDev(),
    geometry: STUDY_AREA.country,
    scale: 3000,
    maxPixels: 1e13
  }).get('constant');

  print('📊 Mean Suitability Score: ' + ee.Number(meanSuitability).format('%.3f'));
  print('📊 Suitability Standard Deviation: ' + ee.Number(stdDevSuitability).format('%.3f'));
};

