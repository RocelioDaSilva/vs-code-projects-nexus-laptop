// =====================================================================
// ENHANCED SOLAR FEASIBILITY MODEL FOR ANGOLA - COMPLETE IMPLEMENTATION
// This script integrates comprehensive satellite data for optimal solar site selection
// =====================================================================

// ---------------------
// 1. DEFINE STUDY AREA
// ---------------------
var country = ee.FeatureCollection('FAO/GAUL/2015/level0')
                .filter(ee.Filter.eq('ADM0_NAME', 'Angola'));
var provinces = ee.FeatureCollection('FAO/GAUL/2015/level1')
                  .filter(ee.Filter.eq('ADM0_NAME', 'Angola'));
Map.centerObject(country, 6);
Map.addLayer(country, {color: 'black'}, 'Angola Boundary');

// --------------------------
// 2. ENHANCED SOLAR RESOURCE DATA
// --------------------------

// ----- 2.1 PRIMARY SOLAR IRRADIATION METRICS -----
// Load Global Solar Atlas for GHI, DNI, DHI
var solarAtlas = ee.Image('projects/solargis-pub/World_PVOUT_GIS_v1').clip(country);
var ghi = solarAtlas.select('ghi').rename('GHI');
var dni = solarAtlas.select('dni').rename('DNI');
var dhi = solarAtlas.select('dhi').rename('DHI');

// Solar Consistency Index (variability metric)
var solarHourly = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
                   .filterDate('2000-01-01', '2020-12-31')
                   .select('surface_solar_radiation_downwards_hourly');
var solarDaily = solarHourly.map(function(img) {
  return img.reduce(ee.Reducer.sum()).divide(3600000);
});
var solarStd = solarDaily.reduce(ee.Reducer.stdDev()).divide(3600000);
var solarConsistency = ghi.divide(solarStd.add(0.1)).unitScale(0, 10).rename('solar_consistency');

// ----- 2.2 WEATHER & ATMOSPHERIC FACTORS -----
// Temperature data
var temperature = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
                    .filterDate('2000-01-01', '2020-12-31')
                    .select('temperature_2m')
                    .mean()
                    .subtract(273.15) // Convert K to C
                    .clip(country)
                    .rename('temperature');

// Temperature penalty (higher temperatures reduce panel efficiency)
var tempPenalty = temperature.multiply(-0.02).add(1.5).clamp(0.8, 1).rename('temp_penalty');

// Wind speed for panel cooling
var windU = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
                .filterDate('2000-01-01', '2020-12-31')
                .select('u_component_of_wind_10m')
                .mean()
                .clip(country);
var windV = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
                .filterDate('2000-01-01', '2020-12-31')
                .select('v_component_of_wind_10m')
                .mean()
                .clip(country);
var windSpeed = windU.pow(2).add(windV.pow(2)).sqrt().rename('wind_speed');
var windCoolingBenefit = windSpeed.multiply(0.03).add(0.95).clamp(0.95, 1.1).rename('wind_cooling_benefit');

// Precipitation for panel cleaning
var precipitation = ee.ImageCollection('ECMWF/ERA5_LAND/HOURLY')
                     .filterDate('2000-01-01', '2020-12-31')
                     .select('total_precipitation_hourly')
                     .sum()
                     .multiply(1000) // Convert m to mm
                     .clip(country)
                     .rename('precipitation');
var precipScore = precipitation.multiply(0.001).add(0.9).clamp(0.9, 1.1).rename('precip_cleaning_benefit');

// Aerosol/dust data (MODIS Deep Blue Aerosol Optical Depth)
var aerosol = ee.ImageCollection('MODIS/006/MCD19A2_GRANULES')
               .filterDate('2010-01-01', '2020-12-31')
               .select('Optical_Depth_047')
               .mean()
               .clip(country)
               .rename('aerosol');
var aerosolPenalty = aerosol.multiply(-0.5).add(1).clamp(0.7, 1).rename('aerosol_penalty');

// ----- 2.3 ENHANCED SOLAR RESOURCE COMPOSITE -----
var enhancedSolarResource = ghi.unitScale(4.5, 6.0)
                              .multiply(tempPenalty)
                              .multiply(windCoolingBenefit)
                              .multiply(aerosolPenalty)
                              .multiply(solarConsistency)
                              .rename('enhanced_solar_score');

// Add visualization layers
Map.addLayer(ghi, {min: 4.0, max: 6.0, palette: ['blue', 'yellow', 'orange', 'red']}, '2.1 GHI (kWh/m2/day)', false);
Map.addLayer(dni, {min: 3.0, max: 5.5, palette: ['blue', 'cyan', 'green', 'yellow']}, '2.2 DNI (kWh/m2/day)', false);
Map.addLayer(solarConsistency, {min: 0, max: 1, palette: ['red', 'yellow', 'green']}, '2.3 Solar Consistency', false);
Map.addLayer(enhancedSolarResource, {min: 0, max: 1, palette: ['red', 'yellow', 'green']}, '2.4 Enhanced Solar Resource Score', true);

// --------------------------
// 3. ENHANCED ENVIRONMENTAL CONSTRAINTS
// --------------------------

// ----- 3.1 TERRAIN & TOPOGRAPHY -----
var elevation = ee.ImageCollection('JAXA/ALOS/AW3D30/V3_2').mosaic().select('DSM').clip(country);
var slope = ee.Terrain.slope(elevation);

// Slope score (gentle slopes better)
var slopeScore = slope.multiply(-0.0667).add(1).clamp(0.1, 1).rename('slope_score');

// Aspect analysis (south-facing optimal in Southern Hemisphere)
var aspect = ee.Terrain.aspect(elevation);
var southFacing = aspect.subtract(180).abs().subtract(45).multiply(-1).unitScale(0, 45);
var aspectScore = southFacing.clamp(0, 1).rename('aspect_score');

// Elevation-based air density correction
var elevationScore = elevation.divide(2000).clamp(0.8, 1.2).rename('elevation_score');

// ----- 3.2 DETAILED SOIL PROPERTIES -----
var soilClay = ee.Image('projects/soilgrids-isric/clay_mean')
                .select('clay_0-5cm_mean')
                .clip(country).divide(10).rename('clay');
var soilSand = ee.Image('projects/soilgrids-isric/sand_mean')
                .select('sand_0-5cm_mean')
                .clip(country).divide(10).rename('sand');
var soilBulkDensity = ee.Image('projects/soilgrids-isric/bdod_mean')
                      .select('bdod_0-5cm_mean')
                      .clip(country).divide(100).rename('bulk_density');

var clayScore = soilClay.subtract(25).abs().multiply(-0.04).add(1).clamp(0.5, 1);
var sandPenalty = soilSand.multiply(-0.01).add(1).clamp(0.6, 1);
var bulkDensityScore = soilBulkDensity.unitScale(1.2, 1.8).clamp(0.7, 1);

var soilStabilityScore = clayScore.multiply(0.4)
                          .add(sandPenalty.multiply(0.3))
                          .add(bulkDensityScore.multiply(0.3))
                          .rename('soil_stability_score');

// ----- 3.3 HYDROLOGY & FLOOD RISK -----
var waterOccurrence = ee.Image('JRC/GSW1_4/GlobalSurfaceWater')
                      .select('occurrence')
                      .clip(country);
var floodRisk = waterOccurrence.divide(100).rename('flood_risk');
var floodSafety = ee.Image(1).subtract(floodRisk).clamp(0.5, 1).rename('flood_safety');

// ----- 3.4 VEGETATION & FIRE RISK -----
var ndvi = ee.ImageCollection('MODIS/006/MOD13Q1')
           .filterDate('2020-01-01', '2021-12-31')
           .select('NDVI')
           .mean()
           .multiply(0.0001)
           .clip(country)
           .rename('NDVI');

var fireCollection = ee.ImageCollection('MODIS/006/MCD64A1')
                      .filterDate('2001-01-01', '2020-12-31')
                      .filterBounds(country)
                      .select('BurnDate');
var fireCount = fireCollection.count().clip(country);
var fireFrequency = fireCount.divide(20).rename('annual_fire_frequency');
var fireRiskScore = fireFrequency.multiply(-1).add(1).clamp(0.3, 1).rename('fire_risk_score');

// Add environmental layers to map
Map.addLayer(slopeScore, {min: 0.1, max: 1, palette: ['red', 'yellow', 'green']}, '3.1 Slope Score', false);
Map.addLayer(aspectScore, {min: 0, max: 1, palette: ['red', 'yellow', 'green']}, '3.2 Aspect Score', false);
Map.addLayer(soilStabilityScore, {min: 0.5, max: 1, palette: ['brown', 'tan', 'green']}, '3.3 Soil Stability Score', false);
Map.addLayer(floodSafety, {min: 0.5, max: 1, palette: ['blue', 'white', 'brown']}, '3.4 Flood Safety', false);
Map.addLayer(fireRiskScore, {min: 0.3, max: 1, palette: ['red', 'yellow', 'green']}, '3.5 Fire Risk Score', false);

// --------------------------
// 4. ENHANCED INFRASTRUCTURE ANALYSIS
// --------------------------

// ----- 4.1 ROAD NETWORK & ACCESSIBILITY -----
var accessibility = ee.Image('Oxford/MAP/accessibility_to_cities_2015_v1_0').clip(country);
var roadAccessScore = accessibility.multiply(-0.0001).add(1).clamp(0.1, 1).rename('road_access_score');

// ----- 4.2 EXISTING TRANSMISSION GRID -----
var gridConnectionScore = accessibility.multiply(-0.00005).add(0.5).clamp(0.1, 1).rename('grid_connection_score');
var gridDistance = accessibility.rename('grid_distance_km'); // Placeholder

// ----- 4.3 PROXIMITY TO ENERGY DEMAND -----
var population = ee.ImageCollection('WorldPop/GP/100m/pop')
                 .filter(ee.Filter.eq('country', 'AGO'))
                 .filter(ee.Filter.eq('year', 2020))
                 .first()
                 .clip(country)
                 .rename('population');

var populationCenters = population.gt(100);
// Note: Using simplified distance calculation
var demandDistance = populationCenters.fastDistanceTransform().sqrt()
    .multiply(0.03).clamp(0, 50).rename('demand_distance_km');
var demandProximityScore = demandDistance.multiply(-0.015).add(1)
    .clamp(0.2, 1).rename('demand_proximity_score');

// ----- 4.4 WATER SOURCE PROXIMITY -----
var permanentWater = ee.Image('JRC/GSW1_4/GlobalSurfaceWater')
                     .select('occurrence')
                     .gt(80);
// Note: Rivers data not accessible, using water bodies only
var waterDistance = permanentWater.fastDistanceTransform().sqrt()
    .multiply(0.03).clamp(0, 25).rename('water_distance_km');
var waterAccessScore = waterDistance.subtract(5).abs().multiply(-0.1).add(1)
    .clamp(0.3, 1).rename('water_access_score');

// ----- 4.5 EXISTING INFRASTRUCTURE CONFLICT -----
var buildings = ee.FeatureCollection('GOOGLE/Research/open-buildings/v3/polygons')
    .filterBounds(country)
    .filter(ee.Filter.gte('confidence', 0.65));
var buildingsImage = ee.Image().byte().paint(buildings, 1);
var buildingBuffer = buildingsImage.fastDistanceTransform().sqrt().multiply(30); // in meters
var infrastructureConflict = buildingBuffer.lt(100).multiply(-1).add(1)
    .rename('infrastructure_conflict');

// ----- 4.6 LINE-OF-SIGHT ANALYSIS -----
var dem = elevation; // Use ALOS elevation
var settlementPoints = ee.FeatureCollection('FAO/GAUL/2015/level2')
                        .filterBounds(country)
                        .limit(50);

// Note: Viewshed analysis not available in Earth Engine, using neutral score
var visibilityScore = ee.Image(0.5).clip(country)
    .rename('visibility_to_settlements');
var losConnectivityScore = visibilityScore.rename('los_connectivity_score');

// ----- 4.7 COMPOSITE INFRASTRUCTURE SCORE -----
var infrastructureWeights = {
    roadAccess: 0.25,
    gridConnection: 0.20,
    demandProximity: 0.25,
    waterAccess: 0.15,
    infrastructureConflict: 0.10,
    losConnectivity: 0.05
};

var compositeInfrastructureScore = roadAccessScore.multiply(infrastructureWeights.roadAccess)
    .add(gridConnectionScore.multiply(infrastructureWeights.gridConnection))
    .add(demandProximityScore.multiply(infrastructureWeights.demandProximity))
    .add(waterAccessScore.multiply(infrastructureWeights.waterAccess))
    .add(infrastructureConflict.multiply(infrastructureWeights.infrastructureConflict))
    .add(losConnectivityScore.multiply(infrastructureWeights.losConnectivity))
    .clamp(0, 1)
    .rename('composite_infrastructure_score');

// Add infrastructure layers to map
Map.addLayer(roadAccessScore, {min: 0.1, max: 1, palette: ['red', 'yellow', 'green']}, 
             '4.1 Road Access Score', false);
Map.addLayer(gridConnectionScore, {min: 0.1, max: 1, palette: ['red', 'yellow', 'green']}, 
             '4.2 Grid Connection Score', false);
Map.addLayer(compositeInfrastructureScore, {min: 0.0, max: 1.0, palette: ['red', 'yellow', 'lime', 'darkgreen']},
             '4.7 Composite Infrastructure Score', false);

// --------------------------
// 5. SOCIO-ECONOMIC FACTORS
// --------------------------

// ----- 5.1 ENERGY NEED INDEX -----
var nightLights = ee.ImageCollection('NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG')
                   .filterDate('2023-01-01', '2023-12-31')
                   .select('avg_rad')
                   .median()
                   .clip(country)
                   .rename('night_lights');

var popNorm = population.unitScale(0, 1000);
var lightsNorm = nightLights.unitScale(0, 30);
var energyNeed = popNorm.multiply(ee.Image(1).subtract(lightsNorm)).rename('energy_need');

// ----- 5.2 COMMUNITY INFRASTRUCTURE PROXIMITY -----
// Note: OpenStreetMap data not accessible, using neutral score
var communityAccess = ee.Image(0.5).rename('community_access');

// ----- 5.3 REGULATORY & LAND-USE FACTORS -----
var landCover = ee.ImageCollection('ESA/WorldCover/v200').first().select('Map').clip(country);

// Land tenure complexity score
var landTenureScore = ee.Image(0.7)
    .where(landCover.eq(10), 0.3)   // Forests
    .where(landCover.eq(20), 0.8)   // Shrubland
    .where(landCover.eq(30), 0.7)   // Grassland
    .where(landCover.eq(40), 0.4)   // Cropland
    .where(landCover.eq(50), 0.2)   // Built-up
    .where(landCover.eq(60), 0.9)   // Bare
    .where(landCover.eq(80), 0.1)   // Water
    .where(landCover.eq(95), 0.3)   // Flooded forest
    .rename('land_tenure_score');

// Population density targeting
var densityTargetScore = population.multiply(-0.005).add(1).clamp(0.2, 0.8)
    .rename('density_target_score');

// Agricultural land suitability
var cropland = landCover.eq(40);
var growingSeasonNDVI = ee.ImageCollection('MODIS/006/MOD13Q1')
    .filterDate('2020-10-01', '2021-04-30')
    .filterBounds(country)
    .select('NDVI')
    .mean()
    .multiply(0.0001)
    .clip(country);
var agProductivity = cropland.multiply(growingSeasonNDVI);
var agSolarSuitability = ee.Image(1).subtract(agProductivity)
    .where(cropland.eq(0), 1)
    .clamp(0.3, 1)
    .rename('ag_solar_suitability');

// ----- 5.4 COMPOSITE REGULATORY SCORE -----
var regulatoryWeights = {
    densityTarget: 0.25,
    landTenure: 0.20,
    communityAccess: 0.25,
    agSuitability: 0.15,
    miningSafety: 0.15
};

var compositeRegulatoryScore = densityTargetScore.multiply(regulatoryWeights.densityTarget)
    .add(landTenureScore.multiply(regulatoryWeights.landTenure))
    .add(communityAccess.multiply(regulatoryWeights.communityAccess))
    .add(agSolarSuitability.multiply(regulatoryWeights.agSuitability))
    .add(ee.Image(0.8).rename('mining_safety_score')) // Placeholder
    .clamp(0, 1)
    .rename('composite_regulatory_score');

// Add socio-economic layers to map
Map.addLayer(energyNeed, {min: 0, max: 1, palette: ['white', 'orange', 'red']}, '5.1 Energy Need Index', false);
Map.addLayer(compositeRegulatoryScore, {min: 0, max: 1, palette: ['red', 'yellow', 'green']}, 
             '5.4 Composite Regulatory Score', false);

// --------------------------
// 6. ANGOLA-SPECIFIC REGIONAL ADJUSTMENTS
// --------------------------

// Create regional masks
var northernRegion = ee.Image.pixelLonLat().select('latitude').gt(-8.0);
var centralRegion = ee.Image.pixelLonLat().select('latitude').lte(-8.0).and(
    ee.Image.pixelLonLat().select('latitude').gt(-12.0));
var southernRegion = ee.Image.pixelLonLat().select('latitude').lte(-12.0);

// Southern Angola dust penalty
var southernDustPenalty = southernRegion.multiply(0.85).where(southernRegion.eq(0), 1.0)
    .rename('southern_dust_penalty');

// Central plateau water scarcity
var centralPlateau = centralRegion.and(elevation.gt(1000));
var centralWaterScarcity = centralPlateau.multiply(0.8).where(centralPlateau.eq(0), 1.0)
    .rename('central_water_penalty');

// Northern constraints
var northernHumidityPenalty = northernRegion.multiply(precipitation.gt(1000)).multiply(0.9)
    .where(northernRegion.eq(0), 1.0).rename('northern_humidity_penalty');
var northernForestConstraint = northernRegion.multiply(landCover.eq(10).or(landCover.eq(95)))
    .multiply(0.7).where(northernRegion.eq(0), 1.0).rename('northern_forest_penalty');

// Combined land-water score
var angolaLandWaterScore = ee.Image(1.0)
    .multiply(southernRegion.multiply(0.9).add(1).subtract(southernRegion.multiply(0.1)))
    .multiply(centralWaterScarcity)
    .multiply(northernHumidityPenalty)
    .multiply(northernForestConstraint)
    .clamp(0.5, 1.0)
    .rename('angola_land_water_score');

// Off-grid priority
var unElectrifiedMask = nightLights.lt(1.0);
var highNeedUnlit = population.multiply(unElectrifiedMask).unitScale(0, 500);
var gridLimitedAreas = gridDistance.gt(20);
var offGridPriority = gridLimitedAreas.multiply(highNeedUnlit).unitScale(0, 1)
    .rename('off_grid_priority_score');

// Regional grid access
var regionalGridAccess = gridConnectionScore
    .multiply(southernRegion.multiply(0.8).add(1).subtract(southernRegion.multiply(0.2)))
    .multiply(northernRegion.multiply(1.1).clamp(0, 1))
    .clamp(0.2, 1.0)
    .rename('regional_grid_access');

// Regional solar adjustment
var regionalSolarAdjustment = ee.Image(1.0)
    .where(southernRegion, 1.15)
    .where(centralRegion, 1.05)
    .where(northernRegion, 0.95)
    .rename('regional_solar_adjustment');

// Composite Angola regional factor
var angolaRegionalWeights = {
    dustSoiling: 0.25,
    landWater: 0.30,
    gridAccess: 0.25,
    offGridPriority: 0.20
};

var angolaRegionalFactor = ee.Image(1.0)
    .multiply(southernDustPenalty.pow(angolaRegionalWeights.dustSoiling))
    .multiply(angolaLandWaterScore.pow(angolaRegionalWeights.landWater))
    .multiply(regionalGridAccess.pow(angolaRegionalWeights.gridAccess))
    .multiply(offGridPriority.add(0.5).pow(angolaRegionalWeights.offGridPriority))
    .clamp(0.6, 1.2)
    .rename('angola_regional_adjustment_factor');

// Add regional layers to map
Map.addLayer(southernRegion, {min: 0, max: 1, palette: ['white', 'yellow']}, '6.1 Southern Region', false);
Map.addLayer(centralRegion, {min: 0, max: 1, palette: ['white', 'green']}, '6.2 Central Region', false);
Map.addLayer(northernRegion, {min: 0, max: 1, palette: ['white', 'blue']}, '6.3 Northern Region', false);
Map.addLayer(angolaRegionalFactor, {min: 0.6, max: 1.2, palette: ['red', 'yellow', 'green']}, 
             '6.4 Angola Regional Adjustment Factor', false);

// --------------------------
// 7. FINAL SUITABILITY MODEL INTEGRATION
// --------------------------

// ----- 7.1 HARD CONSTRAINTS -----
var slopeConstraint = slope.lt(15);
var floodConstraint = floodSafety.gt(0.3);
var urbanConstraint = landCover.neq(50); // Exclude built-up areas
var protectedAreas = ee.FeatureCollection('WCMC/WDPA/current/polygons')
                      .filterBounds(country);
var protectedConstraint = ee.Image().float().paint(protectedAreas, 0).gt(0).not();
var hardConstraints = slopeConstraint
    .and(floodConstraint)
    .and(urbanConstraint)
    .and(protectedConstraint)
    .rename('hard_constraints_mask');

// ----- 7.2 DYNAMIC WEIGHTS -----
var projectType = 0.5; // 0 = off-grid, 1 = grid-connected utility
var dynamicWeights = {
  solarResource: 0.18 + (projectType * 0.04),
  landSuitable: 0.12,
  gentleSlope: 0.08 - (projectType * 0.02),
  floodSafe: 0.08,
  fireSafe: 0.05,
  aspectFavorable: 0.04 + ((1-projectType) * 0.02),
  soilStable: 0.06 + (projectType * 0.02),
  roadAccessible: 0.05 + ((1-projectType) * 0.03),
  gridProximity: 0.03 + (projectType * 0.04),
  waterAvailable: 0.02 + ((1-projectType) * 0.02),
  communityNeed: 0.08,
  regulatoryScore: 0.03,
  angolaRegional: 0.05
};

// ----- 7.3 FINAL SUITABILITY SCORE -----
// Apply hard constraints to base solar resource
var constrainedSolarResource = enhancedSolarResource.multiply(hardConstraints);

// Calculate final suitability score
var suitabilityScore = constrainedSolarResource.multiply(dynamicWeights.solarResource)
    .add(soilStabilityScore.multiply(dynamicWeights.soilStable))
    .add(slopeScore.multiply(dynamicWeights.gentleSlope))
    .add(aspectScore.multiply(dynamicWeights.aspectFavorable))
    .add(floodSafety.multiply(dynamicWeights.floodSafe))
    .add(fireRiskScore.multiply(dynamicWeights.fireSafe))
    .add(roadAccessScore.multiply(dynamicWeights.roadAccessible))
    .add(gridConnectionScore.multiply(dynamicWeights.gridProximity))
    .add(waterAccessScore.multiply(dynamicWeights.waterAvailable))
    .add(energyNeed.multiply(dynamicWeights.communityNeed))
    .add(compositeRegulatoryScore.multiply(dynamicWeights.regulatoryScore))
    .multiply(angolaRegionalFactor.pow(dynamicWeights.angolaRegional))
    .multiply(hardConstraints)
    .pow(1.2) // Non-linear scaling
    .clamp(0, 1)
    .clip(country)
    .rename('final_suitability_score');

// ----- 7.4 RELIABILITY SCORE -----
var dataQuality = solarConsistency
    .multiply(floodSafety.gt(0.7))
    .multiply(soilStabilityScore.gt(0.6));
var reliabilityScore = suitabilityScore.multiply(dataQuality).rename('reliable_suitability_score');

// ----- 7.5 VISUALIZE FINAL RESULTS -----
Map.addLayer(hardConstraints, {min:0, max:1, palette:['red', 'green']}, 
             '7.1 Hard Constraints Mask', false);
Map.addLayer(suitabilityScore, {
  min: 0.0,
  max: 1.0,
  palette: ['red', 'yellow', 'lime', 'darkgreen']
}, '7.2 Final Suitability Score', true);
Map.addLayer(reliabilityScore, {
  min: 0.0,
  max: 1.0,
  palette: ['gray', 'blue', 'green']
}, '7.3 Reliability-Weighted Score', false);

// --------------------------
// 8. ANALYSIS & EXPORT
// --------------------------

// ----- 8.1 PROVINCIAL STATISTICS -----
var provincialStats = suitabilityScore.reduceRegions({
  collection: provinces,
  reducer: ee.Reducer.mean().combine({
    reducer2: ee.Reducer.stdDev(),
    sharedInputs: true
  }),
  scale: 2000,
  tileScale: 8
});

// ----- 8.2 CREATE TOP SITE CANDIDATES -----
var topSites = suitabilityScore.updateMask(suitabilityScore.gt(0.8));
var candidatePoints = topSites.multiply(100).toInt().reduceToVectors({
  geometry: country,
  scale: 2000,
  geometryType: 'centroid',
  labelProperty: 'suitability',
  maxPixels: 1e8
});

// ----- 8.3 VISUALIZATION TOOLS -----
// Add a legend
function addLegend() {
  var panel = ui.Panel({
    style: {
      position: 'bottom-left',
      padding: '8px 15px'
    }
  });
  
  var legend = ui.Panel({
    widgets: [
      ui.Label('SUITABILITY SCORE', {fontWeight: 'bold', fontSize: '16px'}),
      ui.Label('0.0 - 0.3: Poor', {color: 'red'}),
      ui.Label('0.3 - 0.6: Moderate', {color: 'yellow'}),
      ui.Label('0.6 - 0.8: Good', {color: 'lime'}),
      ui.Label('0.8 - 1.0: Excellent', {color: 'darkgreen'})
    ],
    style: {
      backgroundColor: 'white',
      padding: '10px',
      border: '1px solid black'
    }
  });
  
  panel.add(legend);
  Map.add(panel);
}

addLegend();

// ----- 8.4 PRINT STATISTICS -----
print('=== ANGOLA SOLAR FEASIBILITY MODEL ===');
print('Total Area (sq km):', country.geometry().area().divide(1000000));
print('Mean Suitability Score:', suitabilityScore.reduceRegion({
  reducer: ee.Reducer.mean(),
  geometry: country,
  scale: 1000,
  maxPixels: 1e9
}));
print('Area with Score > 0.8 (sq km):', ee.Number(topSites.gt(0.8).multiply(ee.Image.pixelArea())
  .reduceRegion({
    reducer: ee.Reducer.sum(),
